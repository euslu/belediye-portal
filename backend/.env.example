# Gelistirme: true -> mock login, false -> gercek AD
MOCK_AUTH=false
AD_TIMEOUT_MS=10000

# CORS
FRONTEND_URL=http://localhost:5173

# E-posta
MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_ADMIN_EMAIL=
APP_URL=http://localhost:5173

# Grup e-posta adresleri
