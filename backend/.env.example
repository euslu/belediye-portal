PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/belediye_itsm

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Active Directory / LDAP
AD_URL=ldap://
AD_HOST=
AD_PORT=389
AD_DOMAIN=
AD_BASE_DN=
AD_USERNAME=
AD_PASSWORD=
AD_ADMIN_GROUP=Domain Admins
