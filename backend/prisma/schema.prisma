generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Lokasyon ─────────────────────────────────────────────────────────────────
model Location {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  city      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  users   User[]   @relation("UserLocation")
  devices Device[]
}

// ─── Envanter Cihazı (kişisel + ortak) ────────────────────────────────────────
model Device {
  id           Int          @id @default(autoincrement())
  name         String
  type         DeviceType
  brand        String?
  model        String?
  serialNumber String?
  ipAddress    String?
  macAddress   String?
  purchaseDate DateTime?
  warrantyEnd  DateTime?
  status       DeviceStatus @default(ACTIVE)
  isShared     Boolean      @default(false)  // true → ortak cihaz (lokasyona bağlı)
  locationId   Int?
  location     Location?    @relation(fields: [locationId], references: [id])
  assignedTo   String?      // username; null ise ortak cihaz
  assignedUser User?        @relation("UserDevices", fields: [assignedTo], references: [username])
  directorate  String?
  department   String?
  notes        String?
  active       Boolean      @default(true)
  lastSyncAt   DateTime?    // Son AD senkronizasyon zamanı
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  changeLogs   DeviceChangeLog[]
  licenses     DeviceLicense[]
  userDevices  UserDevice[]
}

// ─── Kullanıcı ───────────────────────────────────────────────────────────────
model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  displayName String
  email       String?
  department  String?
  directorate String?
  title       String?
  office           String?  // physicalDeliveryOfficeName (ofis/lokasyon)
  city             String?  // l (ilçe)
  phone            String?  // extensionAttribute1 (GSM)
  ipPhone          String?  // otherIpPhone (dahili)
  employeeNumber   String?  // employeeNumber (sicil/çalışan no)
  departmentNumber String?  // departmentNumber
  // ── Yeni AD alanları ──────────────────────────────────────────────────────
  firstName        String?  // givenName
  lastName         String?  // sn (surname)
  birthday         String?   // birthday (DD.MM.YYYY)
  tcno             String?   // TC kimlik numarası
  employeeId       String?   // employeeID (iç sicil, employeeNumber'dan farklı)
  employeeType     String?   // employeeType (Memur | İşçi | Hizmet Alımı | ...)
  gender           String?   // personalTitle → normalleştirilmiş (Erkek | Kadın)
  managerUsername  String?   // manager DN'den çözümlenen yönetici sAMAccountName
  adCreatedAt      DateTime? // whenCreated — AD hesap oluşturma tarihi
  welcomeMailSent  Boolean   @default(false) // hoş geldiniz maili gönderildi mi
  // ── FlexCity alanları ─────────────────────────────────────────────────────
  flexcityOrgutId  Int?      // ORGUT_ID (KBS örgüt referansı)
  pdksNo           String?   // PDKS_NO
  kadro            String?   // KADRO unvanı (FlexCity'den)
  gorev            String?   // GOREV (FlexCity'den)
  flexSyncedAt     DateTime? // Son FlexCity sync tarihi
  password         String?  // bcrypt hash — yerel test kullanıcıları için
  role             String   @default("user") // "admin" | "manager" | "user"
  locationId  Int?
  location    Location? @relation("UserLocation", fields: [locationId], references: [id])
  createdAt   DateTime @default(now())

  devices           Device[]         @relation("UserDevices")
  tickets           Ticket[]         @relation("CreatedBy")
  assigned          Ticket[]         @relation("AssignedTo")
  groups            UserGroup[]
  activities        TicketActivity[]
  workOrdersCreated  WorkOrder[]      @relation("WOCreatedBy")
  workOrdersAssigned WorkOrder[]     @relation("WOAssignedTo")
  iadeYonlendirmeler Ticket[]        @relation("IadeYonlendir")
}

// ─── Grup ────────────────────────────────────────────────────────────────────
model Group {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  email       String?
  department  String?
  createdAt   DateTime    @default(now())

  members         UserGroup[]
  tickets         Ticket[]
  subjectDefaults Subject[]   @relation("SubjectDefaultGroup")
  categoryDefaults Category[] @relation("CategoryDefaultGroup")
  workOrders      WorkOrder[]
}

// ─── Grup Üyeliği (many-to-many) ─────────────────────────────────────────────
model UserGroup {
  userId  Int
  groupId Int
  role    String @default("member") // "member" | "leader"

  user    User  @relation(fields: [userId], references: [id])
  group   Group @relation(fields: [groupId], references: [id])

  @@id([userId, groupId])
}

// ─── Başvuru Tipi (1. katman: Arıza / Hizmet Talebi) ─────────────────────────
model SubmitType {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  key         String     @unique
  icon        String?
  color       String?    @default("indigo")
  description String?
  active      Boolean    @default(true)
  order       Int        @default(0)

  categories  Category[]
}

// ─── Daire / Birim ────────────────────────────────────────────────────────────
model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  shortCode   String   @unique
  description String?
  isActive    Boolean  @default(true)
  managerId   String?  // AD username
  createdAt   DateTime @default(now())

  categories    Category[]
  tickets       Ticket[]
  workOrders    WorkOrder[]
  transfersFrom TicketTransferLog[] @relation("TransferFrom")
  transfersTo   TicketTransferLog[] @relation("TransferTo")
}

// ─── Kategori (2. katman: kullanıcıya dostça) ────────────────────────────────
model Category {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  icon         String?
  active       Boolean      @default(true)
  typeId       Int?
  submitType   SubmitType?  @relation(fields: [typeId], references: [id])
  departmentId Int?
  department   Department?  @relation(fields: [departmentId], references: [id])
  assignedGroupId  Int?
  assignedGroup    Group?   @relation("CategoryDefaultGroup", fields: [assignedGroupId], references: [id])
  slaHours         Int?
  slaWarningHours  Int?

  subjects   Subject[]
  tickets    Ticket[]
}

// ─── Konu (3. katman: teknik, grup yönlendirmeli) ────────────────────────────
model Subject {
  id             Int      @id @default(autoincrement())
  name           String
  categoryId     Int
  category       Category @relation(fields: [categoryId], references: [id])
  defaultGroupId Int?
  defaultGroup   Group?   @relation("SubjectDefaultGroup", fields: [defaultGroupId], references: [id])
  active         Boolean  @default(true)
  slaHours         Int?
  slaWarningHours  Int?

  tickets Ticket[]
}

// ─── Destek Talebi ───────────────────────────────────────────────────────────
model Ticket {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  status      TicketStatus @default(OPEN)
  type        TicketType   @default(INCIDENT)
  priority    Priority     @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  closedAt    DateTime?

  createdById  Int
  createdBy    User      @relation("CreatedBy", fields: [createdById], references: [id])

  assignedToId Int?
  assignedTo   User?     @relation("AssignedTo", fields: [assignedToId], references: [id])

  groupId      Int?
  group        Group?    @relation(fields: [groupId], references: [id])

  categoryId   Int?
  category     Category? @relation(fields: [categoryId], references: [id])

  subjectId    Int?
  subject      Subject?  @relation(fields: [subjectId], references: [id])

  // Talep kaynağı
  source       TicketSource @default(PORTAL)

  // Onay sistemi
  approvalStatus String?   // PENDING_APPROVAL | APPROVED | REJECTED
  approvedBy     String?   // onaylayan/reddeden kullanıcının username'i
  approvedAt     DateTime?
  rejectedReason String?

  // Çok birimli yapı
  departmentId       Int?
  department         Department? @relation(fields: [departmentId], references: [id])
  targetDeptId       Int?        // cross-transfer hedef daire
  targetDirectorate  String?     // RBAC: hangi daire işleyecek (string)
  targetDepartment   String?     // RBAC: hangi müdürlük işleyecek (string)
  transferNote String?
  transferAt   DateTime?
  transferBy   String?

  // İade sistemi
  iadeDurumu       String?    // PENDING | APPROVED | REJECTED
  iadeAciklama     String?
  iadeYonlendirId  Int?
  iadeYonlendir    User?     @relation("IadeYonlendir", fields: [iadeYonlendirId], references: [id])
  iadeOnayci       String?
  iadeOnayTarih    DateTime?

  // ulakBELL entegrasyonu
  ulakbellToken  String?   // public_token from ulakBELL
  ulakbellNumber Int?      // başvuru numarası
  ulakbellSentAt DateTime? // gönderim zamanı
  ulakbellStatus String?   // son bilinen durum
  ilceId         Int?
  mahalleId      Int?
  sokakId        Int?
  binaId         Int?
  adresId        Int?      // bağımsız bölüm (daire)

  comments      Comment[]
  activities    TicketActivity[]
  notifications NotificationQueue[]
  attachments   Attachment[]
  transferLogs  TicketTransferLog[]
  workOrders    WorkOrder[]
}

// ─── İş Emri ──────────────────────────────────────────────────────────────────
model WorkOrder {
  id             Int             @id @default(autoincrement())
  title          String
  description    String?
  status         WorkOrderStatus @default(TODO)
  priority       Priority        @default(MEDIUM)
  estimatedHours Float?
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  createdById  Int
  createdBy    User        @relation("WOCreatedBy",   fields: [createdById],  references: [id])

  assignedToId Int?
  assignedTo   User?       @relation("WOAssignedTo",  fields: [assignedToId], references: [id])

  groupId      Int?
  group        Group?      @relation(fields: [groupId], references: [id])

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  ticketId     Int?
  ticket       Ticket?     @relation(fields: [ticketId], references: [id])
}

// ─── Daire Aktarma Logu ───────────────────────────────────────────────────────
model TicketTransferLog {
  id          Int        @id @default(autoincrement())
  ticketId    Int
  ticket      Ticket     @relation(fields: [ticketId], references: [id])
  fromDeptId  Int
  fromDept    Department @relation("TransferFrom", fields: [fromDeptId], references: [id])
  toDeptId    Int
  toDept      Department @relation("TransferTo", fields: [toDeptId], references: [id])
  fromGroupId Int?
  toGroupId   Int?
  note        String?
  transferBy  String
  transferAt  DateTime   @default(now())
}

// ─── Yorum ───────────────────────────────────────────────────────────────────
model Comment {
  id         Int      @id @default(autoincrement())
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  ticketId   Int
  ticket     Ticket   @relation(fields: [ticketId], references: [id])
  authorId   Int
}

// ─── Aktivite / Audit Log ────────────────────────────────────────────────────
model TicketActivity {
  id          Int            @id @default(autoincrement())
  ticketId    Int
  ticket      Ticket         @relation(fields: [ticketId], references: [id])
  userId      Int?
  user        User?          @relation(fields: [userId], references: [id])
  action      ActivityAction
  description String?
  fromValue   String?
  toValue     String?
  comment     String?
  createdAt   DateTime       @default(now())
}

// ─── Bildirim Kuyruğu ────────────────────────────────────────────────────────
model NotificationQueue {
  id        Int      @id @default(autoincrement())
  type      String
  payload   Json
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())
  ticketId  Int?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id])
}

// ─── Dosya Ekleri ─────────────────────────────────────────────────────────────
model Attachment {
  id           Int      @id @default(autoincrement())
  ticketId     Int
  ticket       Ticket   @relation(fields: [ticketId], references: [id])
  filename     String
  originalName String
  mimetype     String
  size         Int
  uploadedBy   String
  createdAt    DateTime @default(now())
}

// ─── Sistem Ayarları (key-value) ──────────────────────────────────────────────
model Setting {
  key   String @id
  value String
}

// ─── Kapsamlı Sistem Ayarları (kategorili) ───────────────────────────────────
model SystemSetting {
  id        Int      @id @default(autoincrement())
  category  String   // AD | SMTP | PDKS | FLEXCITY | GENERAL | ITSM
  key       String   @unique
  value     String?
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─── Dashboard Widget Tanımları ───────────────────────────────────────────────
model DashboardWidget {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?
  icon        String?
  roles       String  // CSV: "admin,manager" veya "admin,manager,user"
  defaultOn   Boolean @default(true)
}

// ─── Kullanıcı Dashboard Konfigürasyonu ──────────────────────────────────────
model UserDashboardConfig {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  widgets   String   // aktif widget key listesi JSON
  layout    String?  // grid pozisyon bilgisi JSON
  updatedAt DateTime @updatedAt
}

// ─── Rol Bazlı Dashboard Konfigürasyonu ──────────────────────────────────────
model RoleDashboardConfig {
  id      Int    @id @default(autoincrement())
  role    String @unique
  widgets String // varsayılan widget listesi JSON
}

// ─── Cihaz Değişiklik Logu ───────────────────────────────────────────────────
model DeviceChangeLog {
  id         Int      @id @default(autoincrement())
  deviceId   Int
  device     Device   @relation(fields: [deviceId], references: [id])
  field      String   // Değişen alan: name, ipAddress, notes, assignedTo, vb.
  oldValue   String?
  newValue   String?
  changeType String   // AD_SYNC | MANUAL
  changedBy  String?  // username
  createdAt  DateTime @default(now())
}

// ─── Cihaz Lisansı ──────────────────────────────────────────────────────────
model DeviceLicense {
  id               Int       @id @default(autoincrement())
  deviceId         Int
  device           Device    @relation(fields: [deviceId], references: [id])
  name             String
  key              String?
  baslangicTarihi  DateTime?
  bitisTarihi      DateTime?
  sinirsiz         Boolean   @default(false)
  username         String?
  deviceName       String?
  createdAt        DateTime  @default(now())
}

// ─── Lisans Kaydı (kalıcı, eşleşme bağımsız snapshot) ────────────────────────
// Device/UserDevice silinse bile bu kayıt korunur
model LicenseRecord {
  id               Int       @id @default(autoincrement())
  deviceLicenseId  Int?      // DeviceLicense FK (silinirse null kalır)
  deviceId         Int?      // Device FK (referans)
  deviceName       String    // cihaz adı snapshot
  username         String?   // atanmış kullanıcı snapshot
  directorate      String?   // birim snapshot
  department       String?   // şube snapshot
  licenseName      String    // lisans adı
  licenseKey       String?   // lisans anahtarı
  baslangicTarihi  DateTime?
  bitisTarihi      DateTime?
  sinirsiz         Boolean   @default(false)
  active           Boolean   @default(true) // false = lisans silindi
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── Yazılım Kataloğu ─────────────────────────────────────────────────────────
model SoftwareCatalog {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  category      String?
  totalLicenses Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── AD Değişiklik Logu ───────────────────────────────────────────────────────
model AdChangeLog {
  id          Int      @id @default(autoincrement())
  username    String
  displayName String
  changeType  String   // DEPARTMENT_CHANGE | LEFT_COMPANY | TITLE_CHANGE
  oldValue    String?
  newValue    String?
  detectedAt  DateTime @default(now())
  notified    Boolean  @default(false)
}

// ─── FlexCity KBS Örgüt Ağacı ────────────────────────────────────────────────
model FlexcityOrgut {
  id         Int      @id
  adi        String
  sabitAdi   String?
  kod        String?
  durum      String?
  ustId      Int?
  servisTuru String?
  syncedAt   DateTime @default(now())
}

// ─── Muhtarbis Düzenleme Logu ────────────────────────────────────────────────
model MuhtarbisEditLog {
  id           Int      @id @default(autoincrement())
  objectId     Int
  alan         String
  eskiDeger    String?
  yeniDeger    String?
  duzenleyenId String
  duzenleyenAd String
  tarih        DateTime @default(now())
}

// ─── Kullanıcı-Cihaz Eşleştirme (kalıcı, AD sync korumalı) ─────────────────
model UserDevice {
  id           Int      @id @default(autoincrement())
  username     String
  deviceName   String
  deviceType   String   @default("DIGER")
  serialNumber String?
  deviceId     Int?
  device       Device?  @relation(fields: [deviceId], references: [id])
  assignedAt   DateTime @default(now())
  active       Boolean  @default(true)

  @@unique([username, deviceName])
}

// ─── Enum'lar ─────────────────────────────────────────────────────────────────
// ─── İş Emri Durumu ───────────────────────────────────────────────────────────
enum WorkOrderStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum TicketSource {
  PORTAL
  EMAIL
  PHONE
  IN_PERSON
  API
  MUHTAR
  VATANDAS
  DIGER
}

enum TicketStatus {
  OPEN
  PENDING_APPROVAL
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketType {
  INCIDENT
  REQUEST
  CHANGE
}

enum ActivityAction {
  CREATED
  ASSIGNED
  REASSIGNED
  STATUS_CHANGED
  COMMENTED
  PRIORITY_CHANGED
  GROUP_CHANGED
  APPROVED
  REJECTED
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURN_REJECTED
}

enum DeviceType {
  BILGISAYAR
  DIZUSTU
  IPAD_TABLET
  IP_TELEFON
  MONITOR
  YAZICI
  SWITCH
  ACCESS_POINT
  SUNUCU
  UPS
  DIGER
}

enum DeviceStatus {
  ACTIVE
  PASSIVE
  BROKEN
  TRANSFERRED
}

model MuhtarlikRole {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  displayName String?
  role        String   @default("user")
  directorate String?
  department  String?
  active      Boolean  @default(true)
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ─── Muhtarlık İlçe Yetki Tablosu ────────────────────────────────────────────
// Kullanıcının hangi ilçe(lerde) ne tür yetkisi olduğunu tanımlar.
// yetkiTuru: okuma | yazma | tam
// Daire başkanı (sistemRol=daire_baskani) → tüm ilçeler (bu tablo bypass edilir)
model MuhtarlikYetki {
  id         Int      @id @default(autoincrement())
  username   String
  ilce       String
  yetkiTuru  String   @default("okuma") // okuma | yazma | tam
  active     Boolean  @default(true)
  updatedBy  String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([username, ilce])
}

// ─── Sistem Rol Yönetimi ──────────────────────────────────────────────────────
// admin | daire_baskani | mudur | sef | personel
// Mevcut User.role (admin|manager|user) ile birlikte çalışır.
// Bu tablodaki kayıt varsa sistemRol olarak öncelikli kullanılır.
model UserRole {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  displayName   String?
  role          String   // admin | daire_baskani | mudur | sef | personel
  directorate   String?  // Daire Başkanlığı adı
  department    String?  // Müdürlük adı
  group         String?  // Şeflik/birim
  active        Boolean  @default(true)
  updatedBy     String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model Toplanti {
  id               Int                  @id @default(autoincrement())
  baslik           String
  tarih            DateTime
  saat             String
  yer              String?
  tip              String               @default("muhtarlar")
  durum            String               @default("planli")
  aciklama         String?
  not              String?
  olusturan        String
  olusturmaTarih   DateTime             @default(now())
  guncellenmeTarih DateTime             @updatedAt
  tutanakDosya     String?
  tutanakYukleme   DateTime?
  tutanakYukleyen  String?
  katilimcilar     ToplantiKatilimci[]
  gundemler        ToplantiGundem[]
}

model ToplantiKatilimci {
  id         Int      @id @default(autoincrement())
  toplantiId Int
  toplanti   Toplanti @relation(fields: [toplantiId], references: [id], onDelete: Cascade)
  tip        String
  ad         String
  ilce       String?
  mahalle    String?
  katildi    Boolean  @default(false)
}

model ToplantiGundem {
  id         Int      @id @default(autoincrement())
  toplantiId Int
  toplanti   Toplanti @relation(fields: [toplantiId], references: [id], onDelete: Cascade)
  sira       Int
  konu       String
  aciklama   String?
  sure       Int?
  tamamlandi Boolean  @default(false)
}

model Muhtar {
  id                Int      @id @default(autoincrement())
  ilce              String
  mahalle           String
  muhtarAdi         String
  gsm               String?
  nufus             Int?
  uavt              Int?
  muhtarOfisi       String?
  saglikOcagi       String?
  diniTesis         String?
  okul              String?
  hastane           String?
  sosyalTesis       String?
  cocukOyun         String?
  sporTesisi        String?
  muhtarbisGlobalId String?  @unique
  aktif             Boolean  @default(true)
  sonGuncelleme     DateTime @updatedAt
  olusturmaTarih    DateTime @default(now())
  guncelleyen       String?

  @@unique([ilce, mahalle])
}

model MuhtarlikDuyuru {
  id             Int      @id @default(autoincrement())
  baslik         String
  mesaj          String
  kanallar       String
  ilceler        String
  mahalleler     String?
  hedefSayisi    Int      @default(0)
  smsBasarili    Int      @default(0)
  smsBasarisiz   Int      @default(0)
  emailBasarili  Int      @default(0)
  emailBasarisiz Int      @default(0)
  hata           String?
  gonderen       String
  gonderenAd     String?
  olusturmaTarih DateTime @default(now())

  @@index([olusturmaTarih])
}

model Basvuru {
  id                    Int      @id @default(autoincrement())
  ilce                  String
  mahalle               String
  muhtarAdi             String?
  basvuruTuru           String?
  konu                  String
  aciklama              String?
  daire                 String?
  koordinasyonDaireleri String?
  durum                 String   @default("Beklemede")
  cevap                 String?
  resmiYaziNo           String?
  ekDosya               String?
  tarih                 DateTime @default(now())
  giren                 String
  girenAd               String?
  kaynak                String   @default("muhtarbis")
  muhtarbisId           String?
  guncellemeTarih       DateTime @updatedAt
  guncelleyen           String?
}

model BasvuruAktivite {
  id        Int      @id @default(autoincrement())
  basvuruId Int
  tip       String   // yorum|durum_degisim|daire_atama|sistem
  icerik    String
  eskiDeger String?
  yeniDeger String?
  yapan     String
  yapanAd   String?
  tarih     DateTime @default(now())

  @@index([basvuruId])
}

model GelistirmeTalebi {
  id              Int      @id @default(autoincrement())
  talepEden       String
  talepEdenAd     String?
  baskaAdina      String?
  konu            String
  icerik          String
  aciliyet        String   @default("normal")
  durum           String   @default("beklemede")
  yanit           String?
  olusturmaTarih  DateTime @default(now())
  guncellemeTarih DateTime @updatedAt
}

model IslemGecmisi {
  id          Int      @id @default(autoincrement())
  kullanici   String
  kullaniciAd String?
  islem       String
  modul       String
  kayitId     String?
  detay       String?
  tarih       DateTime @default(now())
  ip          String?
}

// ─── Çalışma Grupları ──────────────────────────────────────────────────────────
model CalismaGrubu {
  id               Int       @id @default(autoincrement())
  ad               String
  aciklama         String?
  directorate      String
  department       String?
  lider            String?
  liderAd          String?
  olusturan        String
  aktif            Boolean   @default(true)
  olusturmaTarih   DateTime  @default(now())
  guncellenmeTarih DateTime  @updatedAt
  uyeler           CalismaGrubuUye[]
}

model CalismaGrubuUye {
  id           Int          @id @default(autoincrement())
  grubuId      Int
  grubu        CalismaGrubu @relation(fields: [grubuId], references: [id], onDelete: Cascade)
  username     String
  displayName  String?
  rol          String       @default("uye")
  eklenmeTarih DateTime     @default(now())

  @@unique([grubuId, username])
}

// ─── Personel Lokasyonu (AD city alanından türetilen çalışma yerleri) ──────────
model Lokasyon {
  id             Int      @id @default(autoincrement())
  ad             String   @unique // "Menteşe 2 Nolu Hizmet Binası"
  kisaAd         String?          // "MHB-2"
  adres          String?
  ilce           String?          // "Menteşe", "Bodrum" vb.
  lat            Float?           // KMZ gelince doldurulacak
  lng            Float?
  tip            String   @default("hizmet_binasi") // hizmet_binasi|mudurluk|saha|istasyon|diger
  aktif          Boolean  @default(true)
  personelSayisi Int?             // cache — güncellenir
  olusturmaTarih DateTime @default(now())
}

// ─── AR-GE: Hat Atama ─────────────────────────────────────────────────────────
model HatAtamasi {
  id               Int       @id @default(autoincrement())
  username         String?
  displayName      String?
  directorate      String?
  department       String?

  hatTipi          String    @default("m2m_data") // ses | m2m_data | ses_data
  hatNo            String?
  operator         String?   // Turkcell | Vodafone | Türk Telekom
  simNo            String?
  iccid            String?   // GSM Hat Seri No (ICCID)
  network          String?   // ARVENTO, mbbapnvf, STATIC IP vb.
  ip               String?   // Static IP varsa
  cihaz            String?   // Araç Takip Cihazı, Telsiz, Tablet vb.
  teslimDurumu     String?   // TESLİM EDİLDİ | YENİ HAT TESLİM EDİLMEDİ

  paket            String?
  aylikUcret       Float?
  baslangicTarih   DateTime?
  bitisTarih       DateTime?

  aktif            Boolean   @default(true)
  notlar           String?

  olusturan        String?
  olusturmaTarih   DateTime  @default(now())
  guncellenmeTarih DateTime  @updatedAt
}

// ─── ulakBELL: Konu → Daire Eşleştirme ──────────────────────────────────────
model UlakbellKonuEslestirme {
  id              Int      @id @default(autoincrement())
  ulakbellKonuId  Int      @unique
  konuAdi         String
  konuTuru        String?
  portalDaire     String?
  portalMudurluk  String?
  ulakbellBirim   String?
  bildirimAktif   Boolean  @default(true)
  aktif           Boolean  @default(true)
}

model UlakbellBildirim {
  id              Int       @id @default(autoincrement())
  konuId          Int
  basvuruNo       Int
  publicToken     String
  basvuruTipi     String?
  basvuranAd      String?
  ilce            String?
  mahalle         String?
  portalDaire     String?
  portalMudurluk  String?
  durum           String   @default("YENI")
  okundu          Boolean  @default(false)
  okunmaTarih     DateTime?
  olusturmaTarih  DateTime @default(now())

  @@index([olusturmaTarih])
  @@index([portalDaire])
  @@index([okundu])
}

// ─── AR-GE: Cihaz Envanteri ──────────────────────────────────────────────────
model CihazEnvanter {
  id               Int       @id @default(autoincrement())
  daireBaskanlik   String?
  kullanici        String?   // personel adı (serbest metin)
  username         String?   // AD username (eşleşirse)
  cihazMarka       String?
  cihazModel       String?
  cihazSeriNo      String?
  cihazTuru        String?   // TABLET | MODEM | IPAD | DİZ ÜSTÜ vb.
  cihazImei        String?
  gsmHatSeriNo     String?   // ICCID
  gsmHatTelNo      String?
  paketTuru        String?
  paketGb          String?
  aktif            Boolean   @default(true)
  notlar           String?
  olusturmaTarih   DateTime  @default(now())
  guncellenmeTarih DateTime  @updatedAt
}

// ─── Menü Yetkilendirme ─────────────────────────────────────────────────────
model MenuPermission {
  id          Int      @id @default(autoincrement())
  menuKey     String   @unique
  label       String
  icon        String?
  route       String
  groupLabel  String?
  groupOrder  Int      @default(0)
  itemOrder   Int      @default(0)
  herkes      Boolean  @default(false)
  disabled    Boolean  @default(false)
  exactEnd    Boolean  @default(false)
  sistemRoller    String?
  directorates    String?
  departments     String?
  grupIds         String?
  usernames       String?
  showApprovalBadge Boolean @default(false)
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}
