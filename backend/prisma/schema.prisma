generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Lokasyon ─────────────────────────────────────────────────────────────────
model Location {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  city      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  users   User[]   @relation("UserLocation")
  devices Device[]
}

// ─── Envanter Cihazı (kişisel + ortak) ────────────────────────────────────────
model Device {
  id           Int          @id @default(autoincrement())
  name         String
  type         DeviceType
  brand        String?
  model        String?
  serialNumber String?
  ipAddress    String?
  macAddress   String?
  purchaseDate DateTime?
  warrantyEnd  DateTime?
  status       DeviceStatus @default(ACTIVE)
  isShared     Boolean      @default(false)  // true → ortak cihaz (lokasyona bağlı)
  locationId   Int?
  location     Location?    @relation(fields: [locationId], references: [id])
  assignedTo   String?      // username; null ise ortak cihaz
  assignedUser User?        @relation("UserDevices", fields: [assignedTo], references: [username])
  directorate  String?
  department   String?
  notes        String?
  active       Boolean      @default(true)
  lastSyncAt   DateTime?    // Son AD senkronizasyon zamanı
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  changeLogs   DeviceChangeLog[]
}

// ─── Kullanıcı ───────────────────────────────────────────────────────────────
model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  displayName String
  email       String?
  department  String?
  directorate String?
  title       String?
  office           String?  // physicalDeliveryOfficeName (ofis/lokasyon)
  city             String?  // l (ilçe)
  phone            String?  // extensionAttribute1 (GSM)
  ipPhone          String?  // otherIpPhone (dahili)
  employeeNumber   String?  // employeeNumber (sicil/çalışan no)
  departmentNumber String?  // departmentNumber
  // ── Yeni AD alanları ──────────────────────────────────────────────────────
  firstName        String?  // givenName
  lastName         String?  // sn (surname)
  birthday         String?   // birthday (DD.MM.YYYY)
  tcno             String?   // TC kimlik numarası
  employeeId       String?   // employeeID (iç sicil, employeeNumber'dan farklı)
  employeeType     String?   // employeeType (Memur | İşçi | Hizmet Alımı | ...)
  gender           String?   // personalTitle → normalleştirilmiş (Erkek | Kadın)
  managerUsername  String?   // manager DN'den çözümlenen yönetici sAMAccountName
  adCreatedAt      DateTime? // whenCreated — AD hesap oluşturma tarihi
  role             String   @default("user") // "admin" | "manager" | "user"
  locationId  Int?
  location    Location? @relation("UserLocation", fields: [locationId], references: [id])
  createdAt   DateTime @default(now())

  devices           Device[]         @relation("UserDevices")
  tickets           Ticket[]         @relation("CreatedBy")
  assigned          Ticket[]         @relation("AssignedTo")
  groups            UserGroup[]
  activities        TicketActivity[]
  workOrdersCreated WorkOrder[]      @relation("WOCreatedBy")
  workOrdersAssigned WorkOrder[]     @relation("WOAssignedTo")
}

// ─── Grup ────────────────────────────────────────────────────────────────────
model Group {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  email       String?
  department  String?
  createdAt   DateTime    @default(now())

  members         UserGroup[]
  tickets         Ticket[]
  subjectDefaults Subject[]   @relation("SubjectDefaultGroup")
  workOrders      WorkOrder[]
}

// ─── Grup Üyeliği (many-to-many) ─────────────────────────────────────────────
model UserGroup {
  userId  Int
  groupId Int
  role    String @default("member") // "member" | "leader"

  user    User  @relation(fields: [userId], references: [id])
  group   Group @relation(fields: [groupId], references: [id])

  @@id([userId, groupId])
}

// ─── Başvuru Tipi (1. katman: Arıza / Hizmet Talebi) ─────────────────────────
model SubmitType {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  key         String     @unique
  icon        String?
  color       String?    @default("indigo")
  description String?
  active      Boolean    @default(true)
  order       Int        @default(0)

  categories  Category[]
}

// ─── Daire / Birim ────────────────────────────────────────────────────────────
model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  shortCode   String   @unique
  description String?
  isActive    Boolean  @default(true)
  managerId   String?  // AD username
  createdAt   DateTime @default(now())

  categories    Category[]
  tickets       Ticket[]
  workOrders    WorkOrder[]
  transfersFrom TicketTransferLog[] @relation("TransferFrom")
  transfersTo   TicketTransferLog[] @relation("TransferTo")
}

// ─── Kategori (2. katman: kullanıcıya dostça) ────────────────────────────────
model Category {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  icon         String?
  active       Boolean      @default(true)
  typeId       Int?
  submitType   SubmitType?  @relation(fields: [typeId], references: [id])
  departmentId Int?
  department   Department?  @relation(fields: [departmentId], references: [id])

  subjects   Subject[]
  tickets    Ticket[]
}

// ─── Konu (3. katman: teknik, grup yönlendirmeli) ────────────────────────────
model Subject {
  id             Int      @id @default(autoincrement())
  name           String
  categoryId     Int
  category       Category @relation(fields: [categoryId], references: [id])
  defaultGroupId Int?
  defaultGroup   Group?   @relation("SubjectDefaultGroup", fields: [defaultGroupId], references: [id])
  active         Boolean  @default(true)

  tickets Ticket[]
}

// ─── Destek Talebi ───────────────────────────────────────────────────────────
model Ticket {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  status      TicketStatus @default(OPEN)
  type        TicketType   @default(INCIDENT)
  priority    Priority     @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  closedAt    DateTime?

  createdById  Int
  createdBy    User      @relation("CreatedBy", fields: [createdById], references: [id])

  assignedToId Int?
  assignedTo   User?     @relation("AssignedTo", fields: [assignedToId], references: [id])

  groupId      Int?
  group        Group?    @relation(fields: [groupId], references: [id])

  categoryId   Int?
  category     Category? @relation(fields: [categoryId], references: [id])

  subjectId    Int?
  subject      Subject?  @relation(fields: [subjectId], references: [id])

  // Talep kaynağı
  source       TicketSource @default(PORTAL)

  // Onay sistemi
  approvalStatus String?   // PENDING_APPROVAL | APPROVED | REJECTED
  approvedBy     String?   // onaylayan/reddeden kullanıcının username'i
  approvedAt     DateTime?
  rejectedReason String?

  // Çok birimli yapı
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  targetDeptId Int?        // cross-transfer hedef daire
  transferNote String?
  transferAt   DateTime?
  transferBy   String?

  // ulakBELL entegrasyonu
  ulakbellToken  String?   // public_token from ulakBELL
  ulakbellNumber Int?      // başvuru numarası
  ulakbellSentAt DateTime? // gönderim zamanı
  ulakbellStatus String?   // son bilinen durum
  ilceId         Int?
  mahalleId      Int?
  sokakId        Int?
  binaId         Int?
  adresId        Int?      // bağımsız bölüm (daire)

  comments      Comment[]
  activities    TicketActivity[]
  notifications NotificationQueue[]
  attachments   Attachment[]
  transferLogs  TicketTransferLog[]
  workOrders    WorkOrder[]
}

// ─── İş Emri ──────────────────────────────────────────────────────────────────
model WorkOrder {
  id             Int             @id @default(autoincrement())
  title          String
  description    String?
  status         WorkOrderStatus @default(TODO)
  priority       Priority        @default(MEDIUM)
  estimatedHours Float?
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  createdById  Int
  createdBy    User        @relation("WOCreatedBy",   fields: [createdById],  references: [id])

  assignedToId Int?
  assignedTo   User?       @relation("WOAssignedTo",  fields: [assignedToId], references: [id])

  groupId      Int?
  group        Group?      @relation(fields: [groupId], references: [id])

  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])

  ticketId     Int?
  ticket       Ticket?     @relation(fields: [ticketId], references: [id])
}

// ─── Daire Aktarma Logu ───────────────────────────────────────────────────────
model TicketTransferLog {
  id          Int        @id @default(autoincrement())
  ticketId    Int
  ticket      Ticket     @relation(fields: [ticketId], references: [id])
  fromDeptId  Int
  fromDept    Department @relation("TransferFrom", fields: [fromDeptId], references: [id])
  toDeptId    Int
  toDept      Department @relation("TransferTo", fields: [toDeptId], references: [id])
  fromGroupId Int?
  toGroupId   Int?
  note        String?
  transferBy  String
  transferAt  DateTime   @default(now())
}

// ─── Yorum ───────────────────────────────────────────────────────────────────
model Comment {
  id         Int      @id @default(autoincrement())
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  ticketId   Int
  ticket     Ticket   @relation(fields: [ticketId], references: [id])
  authorId   Int
}

// ─── Aktivite / Audit Log ────────────────────────────────────────────────────
model TicketActivity {
  id          Int            @id @default(autoincrement())
  ticketId    Int
  ticket      Ticket         @relation(fields: [ticketId], references: [id])
  userId      Int?
  user        User?          @relation(fields: [userId], references: [id])
  action      ActivityAction
  description String?
  fromValue   String?
  toValue     String?
  comment     String?
  createdAt   DateTime       @default(now())
}

// ─── Bildirim Kuyruğu ────────────────────────────────────────────────────────
model NotificationQueue {
  id        Int      @id @default(autoincrement())
  type      String
  payload   Json
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())
  ticketId  Int?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id])
}

// ─── Dosya Ekleri ─────────────────────────────────────────────────────────────
model Attachment {
  id           Int      @id @default(autoincrement())
  ticketId     Int
  ticket       Ticket   @relation(fields: [ticketId], references: [id])
  filename     String
  originalName String
  mimetype     String
  size         Int
  uploadedBy   String
  createdAt    DateTime @default(now())
}

// ─── Sistem Ayarları (key-value) ──────────────────────────────────────────────
model Setting {
  key   String @id
  value String
}

// ─── Kapsamlı Sistem Ayarları (kategorili) ───────────────────────────────────
model SystemSetting {
  id        Int      @id @default(autoincrement())
  category  String   // AD | SMTP | PDKS | FLEXCITY | GENERAL | ITSM
  key       String   @unique
  value     String?
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─── Dashboard Widget Tanımları ───────────────────────────────────────────────
model DashboardWidget {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  name        String
  description String?
  icon        String?
  roles       String  // CSV: "admin,manager" veya "admin,manager,user"
  defaultOn   Boolean @default(true)
}

// ─── Kullanıcı Dashboard Konfigürasyonu ──────────────────────────────────────
model UserDashboardConfig {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  widgets   String   // aktif widget key listesi JSON
  layout    String?  // grid pozisyon bilgisi JSON
  updatedAt DateTime @updatedAt
}

// ─── Rol Bazlı Dashboard Konfigürasyonu ──────────────────────────────────────
model RoleDashboardConfig {
  id      Int    @id @default(autoincrement())
  role    String @unique
  widgets String // varsayılan widget listesi JSON
}

// ─── Cihaz Değişiklik Logu ───────────────────────────────────────────────────
model DeviceChangeLog {
  id         Int      @id @default(autoincrement())
  deviceId   Int
  device     Device   @relation(fields: [deviceId], references: [id])
  field      String   // Değişen alan: name, ipAddress, notes, assignedTo, vb.
  oldValue   String?
  newValue   String?
  changeType String   // AD_SYNC | MANUAL
  changedBy  String?  // username
  createdAt  DateTime @default(now())
}

// ─── AD Değişiklik Logu ───────────────────────────────────────────────────────
model AdChangeLog {
  id          Int      @id @default(autoincrement())
  username    String
  displayName String
  changeType  String   // DEPARTMENT_CHANGE | LEFT_COMPANY | TITLE_CHANGE
  oldValue    String?
  newValue    String?
  detectedAt  DateTime @default(now())
  notified    Boolean  @default(false)
}

// ─── Kullanıcı Cihazları (eski, geriye dönük uyumluluk) ───────────────────────
model UserDevice {
  id           Int      @id @default(autoincrement())
  username     String
  deviceName   String
  deviceType   String   @default("DIGER")
  serialNumber String?
  assignedAt   DateTime @default(now())
  active       Boolean  @default(true)
}

// ─── Enum'lar ─────────────────────────────────────────────────────────────────
// ─── İş Emri Durumu ───────────────────────────────────────────────────────────
enum WorkOrderStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum TicketSource {
  PORTAL
  EMAIL
  PHONE
  IN_PERSON
  API
  MUHTAR
  VATANDAS
  DIGER
}

enum TicketStatus {
  OPEN
  PENDING_APPROVAL
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketType {
  INCIDENT
  REQUEST
  CHANGE
}

enum ActivityAction {
  CREATED
  ASSIGNED
  REASSIGNED
  STATUS_CHANGED
  COMMENTED
  PRIORITY_CHANGED
  GROUP_CHANGED
  APPROVED
  REJECTED
}

enum DeviceType {
  BILGISAYAR
  DIZUSTU
  IPAD_TABLET
  IP_TELEFON
  MONITOR
  YAZICI
  SWITCH
  ACCESS_POINT
  SUNUCU
  UPS
  DIGER
}

enum DeviceStatus {
  ACTIVE
  PASSIVE
  BROKEN
  TRANSFERRED
}
