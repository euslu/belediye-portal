{
  "name": "belediye-portal",
  "version": "1.0.0",
  "description": "Mugla Buyuksehir Belediyesi - Uygulama Portali",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
